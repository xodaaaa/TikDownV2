# =============================================================================
# TikDown — Variables de entorno
# =============================================================================
# Copia este archivo a .env y edita los valores según tu entorno.
# Las variables marcadas como opcionales pueden dejarse vacías.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
# SECRET_KEY y FERNET_KEY: vacías por defecto → la app usa/genera archivos
# del volumen (§6.8). Para forzarlas en .env, genera con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=
FERNET_KEY=
DATABASE_PATH=/app/data/tikdown.db
SCHEDULER_DB_PATH=/app/data/scheduler.db
VIDEOS_DIR=/app/data/videos
BACKUPS_DIR=/app/data/backups
LOG_LEVEL=INFO
MONITOR_AUTOSTART=false
FORCE_RESET=false
ENABLE_API_DOCS=false
CORS_ORIGINS=http://localhost:5173

# ── Monitor ───────────────────────────────────────────────────────────────────
MONITOR_INTERVAL_MINUTES=10
MIN_MONITOR_INTERVAL_MINUTES=5
MAX_CONCURRENT_DOWNLOADS=2
MIN_DELAY_SECONDS=10
MAX_DELAY_SECONDS=60
BACKOFF_MAX_SECONDS=1800
CIRCUIT_BREAKER_FAILS=5
DOWNLOAD_TIMEOUT_SECONDS=600
CHECK_NOW_THROTTLE_SECONDS=30
PROFILE_REFRESH_HOURS=48
DISK_MONITOR_INTERVAL_SECONDS=300
NETWORK_PROBE_INTERVAL=30
NETWORK_OFFLINE_THRESHOLD=3
NETWORK_PROBE_URL=https://1.1.1.1
EVENTS_RETENTION_DAYS=7
LOG_BUFFER_SIZE=1000

# ── Backfill ──────────────────────────────────────────────────────────────────
BACKFILL_DELAY_MIN=5
BACKFILL_DELAY_MAX=15
BACKFILL_PAUSE_EVERY_N=50
BACKFILL_LONG_PAUSE_MIN=60
BACKFILL_LONG_PAUSE_MAX=120

# ── Notificaciones (opcionales, off por defecto) ──────────────────────────────
ENABLE_EXTERNAL_NOTIFICATIONS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_MODE=notifications
TELEGRAM_POLLING_INTERVAL=3

# ── Frontend (Vite, prefijo VITE_) ────────────────────────────────────────────
# En prod: deja VITE_API_URL vacío (URL relativa al mismo origen que el backend).
# En dev: setea http://localhost:8000 para que Vite hable con el backend en otro puerto.
VITE_API_URL=
VITE_SSE_URL=
VITE_PUBLIC_PATH=/
# VITE_THEME_DEFAULT=dark    # Comentada: si NO se define, respeta prefers-color-scheme del SO (§12.14). Descomenta y setea 'dark' o 'light' para forzar.
